# ==============================================================
# NovaTicket Backend — Environment Variables Example
# Copy this file to backend/.env and fill in real values
# NEVER commit .env to git
# ==============================================================

# ----------------------------
# Application
# ----------------------------
ENVIRONMENT=development
DEBUG=true
APP_NAME=NovaTicket API
APP_VERSION=1.0.0

# ----------------------------
# Security
# ----------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------
# Microsoft SQL Server
# ----------------------------
# Format: mssql+pyodbc://user:password@host:port/database?driver=ODBC+Driver+18+for+SQL+Server
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=novaticket
MSSQL_USER=sa
MSSQL_PASSWORD=your-strong-password-here
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# ----------------------------
# CORS
# ----------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------
# ML Model Artifacts
# ----------------------------
MODEL_DIR=models
